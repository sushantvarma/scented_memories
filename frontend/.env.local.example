# ── ScentedMemories frontend environment variables ───────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# Spring Boot backend base URL (no trailing slash).
#
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8080
#
# Production (set this in Vercel dashboard, not here):
# NEXT_PUBLIC_API_URL=https://scented-memories-backend.onrender.com
